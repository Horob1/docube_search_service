# ============================================================
# Search Service — Environment Variables
# ============================================================
# Copy this file to .env and adjust values for your environment.
# Docker Compose will automatically load .env file.
# ============================================================

# Elasticsearch
ES_PASSWORD=horob1@2410
ES_USERNAME=elastic
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Redis (hostname in Docker network)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=2410

# Kafka (hostname in Docker network)
KAFKA_BOOTSTRAP=kafka:7092

# Eureka (hostname in Docker network)
EUREKA_URL=http://eureka-server:9000/eureka

